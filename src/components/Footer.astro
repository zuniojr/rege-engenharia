<footer class="footer">
  <div class="container footer-content">
    <div class="footer-col brand-col">
      <div class="footer-logo-wrap">
        <img src="/images/logo.png" alt="Regê Engenharia" class="footer-logo-img" />
      </div>
      <p class="brand-tagline">"Projetando espaços, construindo sonhos."</p>
    </div>
    <div class="footer-col">
      <h3>Contato</h3>
      <ul>
        <li><a href="tel:+5547992184100">(47) 99218-4100</a></li>
        <li>Rua Onório Bortolato, 2517</li>
        <li>Navegantes - SC</li>
      </ul>
    </div>
    <div class="footer-col">
      <h3>Links Rápidos</h3>
      <ul>
        <li><a href="/">Início</a></li>
        <li><a href="#diferenciais">Serviços</a></li>
        <li><a href="#portfolio">Portfólio</a></li>
        <li><a href="#depoimentos">Depoimentos</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Regê Engenharia. Todos os direitos reservados. | Desenvolvido com sofisticação.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--navy);
    color: var(--white);
    padding: var(--spacing-lg) 0 0 0;
    border-top: 1px solid var(--line);
    font-family: var(--font-body);
  }
  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-bottom: var(--spacing-lg);
  }
  
  .brand-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .footer-logo-wrap {
    display: flex;
    align-items: center;
  }
  .footer-logo-img {
    height: 55px;
    width: auto;
    display: block;
  }
  .brand-tagline {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--sand);
    font-size: 1.1rem;
    margin: 0;
    max-width: 300px;
  }

  .footer-col h3 {
    color: var(--white);
    margin-bottom: 1.5rem;
    font-family: var(--font-hero);
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    position: relative;
    padding-bottom: 0.5rem;
  }
  .footer-col h3::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 30px;
    height: 2px;
    background-color: var(--sand);
  }
  
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col ul li {
    margin-bottom: 0.8rem;
    color: var(--sand-2);
    font-size: 0.9rem;
    transition: var(--transition);
  }
  .footer-col a {
    color: var(--sand-2);
    transition: var(--transition);
  }
  .footer-col a:hover {
    color: var(--white);
    padding-left: 3px;
  }
  .footer-bottom {
    background-color: var(--navy-2);
    text-align: center;
    padding: 1.5rem;
    font-size: 0.85rem;
    color: var(--sand-2);
    border-top: 1px solid var(--line);
  }
</style>
