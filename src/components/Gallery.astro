---
const categories = [
  { name: 'Cozinha Planejada', img: 'cozinha.jpg' },
  { name: 'Paineis Ripados', img: 'painel-ripado.webp' },
  { name: 'Dormitórios', img: 'dormitorio.jpg' },
  { name: 'Espaço Gourmet', img: 'espaco-gourmet.jpg' },
  { name: 'Banheiro', img: 'banheiro.jpg' },
  { name: 'Lavanderia', img: 'lavanderia.jpg' },
  { name: 'Closet Planejado', img: 'closet.jpg' },
  { name: 'Home Office', img: 'home-office.jpg' },
  { name: 'Corporativo', img: 'corporativo.jpg' },
  { name: 'Ambientes Personalizados', img: 'ambientes-personalizados.jpg' },
  { name: 'Cabeceira de Cama e Porta de Correr', img: 'cabeceira-cama.jpg' },
  { name: 'Painel de TV Sob Medida', img: 'painel-tv.jpg' }
];
---

<div class="gallery-section">
  <div class="container">
    <h2 class="section-title">Portfólio de Ambientes</h2>

    <!-- Primeira metade: 6 primeiros itens (2 linhas de 3) -->
    <div class="gallery-grid">
      {categories.slice(0, 6).map((cat) => (
        <div class="gallery-card">
          <div class="gallery-img-wrap">
            <img src={`/images/${cat.img}`} alt={cat.name} loading="lazy" />
          </div>
          <p class="gallery-label">{cat.name.toUpperCase()}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- Banner preto de largura total -->
<div class="gallery-banner">
  <p>MÓVEIS QUE SE ENCAIXAM PERFEITAMENTE NA SUA VIDA E NA SUA CASA.</p>
</div>

<!-- Segunda metade: 6 últimos itens (2 linhas de 3) -->
<div class="gallery-section">
  <div class="container">
    <div class="gallery-grid">
      {categories.slice(6).map((cat) => (
        <div class="gallery-card">
          <div class="gallery-img-wrap">
            <img src={`/images/${cat.img}`} alt={cat.name} loading="lazy" />
          </div>
          <p class="gallery-label">{cat.name.toUpperCase()}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .gallery-section {
    background-color: #ffffff;
    padding: 2rem 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gallery-card {
    text-align: center;
  }

  .gallery-img-wrap {
    overflow: hidden;
    border-radius: 6px;
    aspect-ratio: 4 / 3;
  }

  .gallery-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-img-wrap:hover img {
    transform: scale(1.05);
  }

  .gallery-label {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-dark);
    letter-spacing: 1px;
    margin: 0.75rem 0 0;
    text-transform: uppercase;
  }

  /* Banner preto */
  .gallery-banner {
    width: 100%;
    background-color: #111111;
    text-align: center;
    padding: 2rem 1rem;
  }

  .gallery-banner p {
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
    font-weight: 700;
  }

  /* Responsivo */
  @media (max-width: 992px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 576px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
