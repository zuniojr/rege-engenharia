---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 3-9.6 9.6"/><path d="m15.5 7.5 3 3"/><path d="m18.5 4.5 3 3"/></svg>`,
    title: "Da Concepção à Chave na Mão",
    text: "Cuidamos de todo o processo da sua obra, desde os primeiros esboços arquitetônicos e modelagem 3D até a limpeza pós-obra e a entrega final das chaves. Tranquilidade absoluta para você.",
    theme: "navy"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v18"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M8 14h8"/><path d="M8 18h8"/></svg>`,
    title: "Projetos Personalizados",
    text: "Desenvolvemos de forma integrada projetos de arquitetura, design de interiores, cálculo estrutural e instalações. Soluções inteligentes pensadas sob medida para o seu estilo de vida.",
    theme: "sand"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><circle cx="10" cy="15" r="2"/><path d="m11.5 16.5 3 3"/></svg>`,
    title: "Aprovações e Regularizações",
    text: "Toda a burocracia legal simplificada. Atuamos na aprovação de projetos junto à Prefeitura, licenciamento do Corpo de Bombeiros, averbações e regularização completa de registros de imóveis.",
    theme: "navy"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22h20"/><path d="M16 22V2h-4v20"/><path d="M12 5h8"/><path d="M12 9h8"/><path d="M8 22V10H4v12"/></svg>`,
    title: "Execução & Gestão de Obras",
    text: "Gestão técnica rigorosa do canteiro de obras. Garantimos fidelidade ao projeto, cumprimento dos prazos, controle financeiro transparente, uso de materiais certificados e máxima segurança estrutural.",
    theme: "sand"
  }
];
---

<section class="services-section" id="diferenciais">
  <div class="container">
    <div class="section-header">
      <span class="subtitle">CONFIANÇA E EXCELÊNCIA TÉCNICA</span>
      <h2 class="section-title">SERVIÇOS & SOLUÇÕES</h2>
      <p class="section-desc">Cuidamos de todo o processo para você focar no que realmente importa: a realização do seu sonho.</p>
    </div>
    
    <div class="services-grid">
      {services.map((svc) => (
        <div class={`service-card service-${svc.theme}`}>
          <div class="icon-wrapper" set:html={svc.icon} />
          <h3 class="card-title">{svc.title}</h3>
          <div class="card-divider"></div>
          <p class="card-text">{svc.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: var(--spacing-xl) 0;
    background-color: var(--white);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .subtitle {
    display: block;
    font-size: 0.8rem;
    color: var(--sand-2);
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 0.75rem;
    font-family: var(--font-hero);
    font-weight: 700;
  }
  
  .section-title {
    font-family: var(--font-hero);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--navy);
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .section-desc {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: 1.15rem;
    color: #555;
    margin: 0;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  
  .service-card {
    padding: 3rem 2.5rem;
    border-radius: 4px;
    transition: var(--transition);
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .service-navy {
    background-color: var(--navy);
    color: var(--white);
    border-color: transparent;
  }
  .service-navy .icon-wrapper {
    color: var(--sand);
  }
  .service-navy .card-title {
    color: var(--white);
  }
  .service-navy .card-divider {
    background-color: var(--line);
  }
  .service-navy .card-text {
    color: var(--sand-2);
  }

  .service-sand {
    background-color: var(--sand);
    color: var(--navy);
    border-color: transparent;
  }
  .service-sand .icon-wrapper {
    color: var(--navy);
  }
  .service-sand .card-title {
    color: var(--navy);
  }
  .service-sand .card-divider {
    background-color: rgba(27, 36, 48, 0.15);
  }
  .service-sand .card-text {
    color: var(--navy-2);
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(27, 36, 48, 0.15);
  }
  
  .icon-wrapper {
    display: inline-flex;
    margin-bottom: 1.5rem;
  }
  
  .icon-wrapper :global(svg) {
    width: 44px;
    height: 44px;
  }
  
  .card-title {
    font-family: var(--font-hero);
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-divider {
    width: 40px;
    height: 2px;
    margin-bottom: 1.25rem;
  }
  
  .card-text {
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
  }
  
  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .service-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
