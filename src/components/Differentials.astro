---
const differentials = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Variedade de Produtos",
    text: "Ampla variedade de materiais, além de móveis planejados feitos sob medida e diversas opções de cores e layout."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/><path d="M5 3 2 6"/><path d="m22 6-3-3"/><path d="M6.38 18.7 4 21"/><path d="M17.64 18.67 20 21"/></svg>`,
    title: "Prazo de Entrega",
    text: "Um dos diferenciais da Detaliê Móveis Sob Medida é o seu compromisso com o prazo de entrega. A empresa trabalha com agilidade e eficiência para garantir que os projetos sejam entregues no prazo estabelecido, evitando atrasos e transtornos para os clientes."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/></svg>`,
    title: "Atendimento Especializado",
    text: "Nossa equipe de especialistas disponibilizam um atendimento personalizado para auxiliar na definição dos melhores produtos para sua casa. Com atenção aos detalhes e um compromisso com a satisfação do cliente, a Detaliê Móveis Sob Medida busca superar as expectativas em cada projeto."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>`,
    title: "Pagamento Facilitado",
    text: "Temos como um dos nossos diferenciais oferecer preços competitivos no mercado, sem abrir mão da qualidade dos nossos produtos e serviços. Além disso, buscamos facilitar as condições de pagamento, oferecendo opções variadas que se adequam às necessidades de cada cliente."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>`,
    title: "Projetos Sob Medida",
    text: "Nossos projetos são personalizados para atender às necessidades específicas de cada cliente. Trabalhamos em estreita colaboração com os clientes para criar soluções sob medida que se adaptem ao seu estilo de vida e orçamento."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "Garantia Diferenciada",
    text: "Oferecemos garantia diferenciada em nossos produtos e serviços, assegurando a qualidade e durabilidade dos materiais utilizados em nossos projetos. A Detaliê Móveis Sob Medida trabalha com os melhores fornecedores do mercado, que oferecem produtos de alta qualidade."
  }
];
---

<section class="differentials-section" id="diferenciais">
  <div class="container">
    <div class="section-header">
      <span class="subtitle">A VARIEDADE QUE VOCÊ PRECISA PARA DECORAR SEU ESPAÇO</span>
      <h2 class="section-title">DIFERENCIAIS DA DETALIÊ</h2>
    </div>
    
    <div class="differentials-grid">
      {differentials.map((diff) => (
        <div class="differential-card">
          <div class="icon-wrapper" set:html={diff.icon} />
          <h3 class="card-title">{diff.title}</h3>
          <p class="card-text">{diff.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .differentials-section {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-white);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }
  
  .subtitle {
    display: block;
    font-size: 0.85rem;
    color: var(--color-gray-medium);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 600;
  }
  
  .section-title {
    font-family: var(--font-section);
    font-size: 3rem;
    color: var(--color-black);
    margin: 0;
    letter-spacing: 1px;
  }
  
  .differentials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  
  .differential-card {
    text-align: center;
    padding: 1rem;
  }
  
  .icon-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
    color: var(--color-dark);
  }
  
  .icon-wrapper :global(svg) {
    width: 50px;
    height: 50px;
    stroke-width: 1.5;
  }
  
  .card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: 1rem;
  }
  
  .card-text {
    font-size: 0.95rem;
    color: var(--color-gray-medium);
    line-height: 1.8;
  }
  
  @media (max-width: 992px) {
    .differentials-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }
  
  @media (max-width: 768px) {
    .differentials-grid {
      grid-template-columns: 1fr;
    }
    
    .section-title {
      font-size: 2.5rem;
    }
    
    .differentials-section {
      padding: var(--spacing-lg) 0;
    }
  }
</style>
