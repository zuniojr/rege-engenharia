---
<!-- Top Bar (white) -->
<header class="top-bar">
  <div class="container top-bar-inner">
    <span class="top-bar-item">
      <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true">
        <path d="M6.62 10.79a15.15 15.15 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.11-.27 11.72 11.72 0 0 0 3.7.59 1 1 0 0 1 1 1v3.44a1 1 0 0 1-1 1A17 17 0 0 1 2 4a1 1 0 0 1 1-1h3.44a1 1 0 0 1 1 1 11.72 11.72 0 0 0 .59 3.7 1 1 0 0 1-.27 1.1l-2.2 2.2z"/>
      </svg>
      <a href="tel:+5547992184100">(47) 99218-4100</a>
    </span>
    <span class="top-bar-sep">|</span>
    <span class="top-bar-item">
      <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/>
      </svg>
      <a href="https://www.google.com/maps/place/R.+On%C3%B3rio+Bortolato,+2517" target="_blank" rel="noopener noreferrer">Rua Onório Bortolato, 2517 – Navegantes – SC</a>
    </span>
  </div>
</header>

<!-- Main Header (glassmorphism navy, sticky) -->
<header class="main-header">
  <div class="container nav-bar-inner">
    <a href="/" class="nav-logo" aria-label="Regê Engenharia Home">
      <img src="/images/logo.png" alt="Regê Engenharia" class="nav-logo-img" />
    </a>
    <nav class="nav-menu" aria-label="Menu principal">
      <a href="/">Início</a>
      <a href="#diferenciais">Serviços</a>
      <a href="#portfolio">Portfólio</a>
      <a href="#depoimentos">Depoimentos</a>
      <a href="https://wa.me/5547992184100?text=Olá,%20gostaria%20de%20solicitar%20um%20orçamento." target="_blank" rel="noopener noreferrer" class="nav-cta-btn">Orçamento</a>
    </nav>
    <button class="mobile-menu-toggle" aria-label="Abrir menu" aria-expanded="false">
      <svg class="hamburger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line class="line-top" x1="4" y1="6" x2="20" y2="6"></line>
        <line class="line-mid" x1="4" y1="12" x2="20" y2="12"></line>
        <line class="line-bot" x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<style>
  /* Containers */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-sm);
    width: 100%;
    box-sizing: border-box;
  }

  /* Top Bar */
  .top-bar {
    background: var(--white);
    color: var(--navy);
    border-bottom: 1px solid rgba(27, 36, 48, 0.08);
    font-family: var(--font-body);
    font-size: 0.82rem;
  }
  .top-bar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 0.4rem var(--spacing-sm);
  }
  .top-bar-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .top-bar-item a {
    color: var(--navy);
    text-decoration: none;
    transition: var(--transition);
  }
  .top-bar-item a:hover { color: var(--sand-2); }
  .top-bar-item svg { color: var(--navy); flex-shrink: 0; opacity: 0.8; }
  .top-bar-sep { color: rgba(27, 36, 48, 0.2); font-size: 0.9rem; }

  /* Main Header */
  .main-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(27, 36, 48, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
    padding: 0.6rem 0;
  }
  .nav-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .nav-logo-img {
    height: 45px;
    width: auto;
    display: block;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-menu a {
    color: var(--white);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: var(--transition);
  }
  .nav-menu a:hover:not(.nav-cta-btn) { 
    color: var(--sand); 
    border-bottom-color: var(--sand); 
  }
  
  .nav-cta-btn {
    background-color: var(--sand);
    color: var(--navy) !important;
    padding: 0.5rem 1.2rem;
    border-radius: 3px;
    font-weight: 700 !important;
    border: 1px solid transparent !important;
  }
  .nav-cta-btn:hover {
    background-color: transparent !important;
    color: var(--sand) !important;
    border-color: var(--sand) !important;
    transform: translateY(-1px);
  }

  /* Hambúrguer */
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--white);
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1100;
  }
  .mobile-menu-toggle svg {
    width: 28px;
    height: 28px;
    transition: transform 0.3s ease;
  }
  .mobile-menu-toggle line {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  /* Hamburger animado */
  .mobile-menu-toggle.is-active .line-top {
    transform: translateY(6px) rotate(45deg);
  }
  .mobile-menu-toggle.is-active .line-mid {
    opacity: 0;
  }
  .mobile-menu-toggle.is-active .line-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .mobile-menu-toggle {
      display: block;
    }

    .nav-logo-img {
      height: 25px;
    }
    
    .nav-bar-inner {
      justify-content: space-between;
    }

    .nav-menu {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(27, 36, 48, 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      z-index: 1050;
      gap: 2.5rem;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .nav-menu.is-active {
      transform: translateX(0);
    }

    .nav-menu a {
      font-size: 1.25rem;
      letter-spacing: 2px;
    }

    .top-bar-sep { display: none; }
    .top-bar-inner { 
      flex-direction: column; 
      gap: 0.4rem; 
      justify-content: center;
      align-items: center;
      text-align: center; 
    }
  }
</style>

<script>
  const toggleBtn = document.querySelector('.mobile-menu-toggle');
  const navMenu = document.querySelector('.nav-menu');
  const menuLinks = document.querySelectorAll('.nav-menu a');

  if (toggleBtn && navMenu) {
    const toggleMenu = () => {
      const isActive = toggleBtn.classList.toggle('is-active');
      navMenu.classList.toggle('is-active');
      toggleBtn.setAttribute('aria-expanded', isActive.toString());
      document.body.style.overflow = isActive ? 'hidden' : '';
    };

    toggleBtn.addEventListener('click', toggleMenu);

    menuLinks.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.classList.remove('is-active');
        navMenu.classList.remove('is-active');
        toggleBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }
</script>
