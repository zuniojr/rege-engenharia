<style>
/* FOOTER */
.v2-footer {
  background: var(--v2-dark);
  border-top: 1px solid var(--v2-border);
  padding: 5rem 0 0;
}
.v2-footer-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 3rem;
  padding-bottom: 4rem;
  max-width: 1200px;
  margin: 0 auto;
}
.v2-footer-brand {
  flex: 1 1 300px;
  max-width: 400px;
}
.v2-footer-brand p {
  font-size: 0.88rem;
  color: var(--v2-muted);
  line-height: 1.7;
  margin-top: 1.25rem;
}
.v2-footer-nav { 
  display: flex; 
  flex-direction: column; 
  gap: 1rem; 
  flex: 1 1 150px;
}
.v2-footer-nav h4 {
  font-family: var(--v2-font-body);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--v2-white);
  margin-bottom: 0.5rem;
}
.v2-footer-nav a {
  font-size: 0.88rem;
  color: var(--v2-muted);
  text-decoration: none;
  transition: color 0.2s;
}
.v2-footer-nav a:hover { color: var(--v2-gold); }

.v2-footer-bottom {
  border-top: 1px solid var(--v2-border);
  background: var(--v2-dark);
}
.v2-footer-bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 1.5rem;
  max-width: 1200px;
  margin: 0 auto;
}
.v2-footer-bottom p { font-size: 0.78rem; color: rgba(255,255,255,0.6); margin: 0; }
.v2-footer-social {
  display: flex;
  gap: 1.5rem;
}
.v2-footer-social a {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.2s;
}
.v2-footer-social a:hover { color: var(--v2-gold); }

.v2-logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}
.v2-logo-img {
  height: 40px;
  width: auto;
  display: block;
}

@media (max-width: 768px) {
  .v2-footer-inner {
    gap: 2.5rem;
  }
}

@media (max-width: 600px) {
  .v2-footer-bottom-inner {
    flex-direction: column;
    text-align: center;
    gap: 1rem;
  }
  .v2-footer-brand {
    max-width: 100%;
  }
}
</style>
