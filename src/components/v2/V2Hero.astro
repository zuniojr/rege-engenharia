---
---

<section class="v2-hero" id="v2-hero">
  <div class="v2-hero-bg">
    <img src="/images/hero-rege.png" alt="Obra Regê Engenharia" />
    <div class="v2-hero-overlay"></div>
  </div>

  <div class="v2-hero-content">
    <div class="v2-hero-badge">
      <span class="v2-badge-dot"></span>
      NAVEGANTES · SC
    </div>
    <h1 class="v2-hero-title">
      <span class="v2-title-line" style="animation-delay:0.3s">PROJETANDO</span>
      <span class="v2-title-line v2-title-accent" style="animation-delay:0.45s">ESPAÇOS,</span>
      <span class="v2-title-line v2-title-stroke" style="animation-delay:0.6s">CONSTRUINDO HISTÓRIAS.</span>
    </h1>
    <p class="v2-hero-sub">
      Da concepção à chave na mão — engenharia de excelência,
      transparência absoluta e resultado que supera expectativas.
    </p>
    <div class="v2-hero-actions">
      <a href="https://bitlybr.net/rege" class="v2-btn v2-btn-primary" target="_blank" rel="noopener noreferrer">
        <span>Iniciar Projeto</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#v2-portfolio" class="v2-btn v2-btn-ghost">Ver Portfólio</a>
    </div>
  </div>
  <div class="v2-hero-scroll-hint" aria-hidden="true">
    <div class="v2-scroll-line"></div>
    <span>SCROLL</span>
  </div>
</section>

<style>
/* HERO */
.v2-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background: var(--v2-dark);
}
.v2-hero-bg {
  position: absolute;
  inset: 0;
}
.v2-hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.85;
  filter: contrast(1.05);
}
.v2-hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(8,14,23,0.88) 30%, rgba(8,14,23,0.15) 100%),
    linear-gradient(to top, rgba(8,14,23,0.75) 0%, transparent 60%);
}
.v2-hero-content {
  position: relative;
  z-index: 10;
  padding: 10rem 1.5rem 6rem;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}
.v2-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--v2-gold);
  border: 1px solid rgba(201,168,76,0.3);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: v2fadeUp 0.8s var(--v2-ease-out) 0.1s forwards;
}
.v2-badge-dot {
  width: 6px;
  height: 6px;
  background: var(--v2-gold);
  border-radius: 50%;
  animation: v2pulse 2s infinite;
}
@keyframes v2pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}
.v2-hero-title {
  display: flex;
  flex-direction: column;
  font-family: var(--v2-font-display);
  font-size: clamp(3rem, 7vw, 6rem);
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2px;
  text-transform: uppercase;
  margin: 0 0 2rem;
  color: var(--v2-white);
}
.v2-title-line {
  opacity: 0;
  transform: translateY(30px);
  animation: v2fadeUp 0.8s var(--v2-ease-out) forwards;
}
.v2-title-accent { color: var(--v2-gold); }
.v2-title-stroke {
  -webkit-text-stroke: 2px var(--v2-white);
  color: transparent;
}
@keyframes v2fadeUp {
  to { opacity: 1; transform: translateY(0); }
}
.v2-hero-sub {
  font-family: var(--v2-font-serif);
  font-style: italic;
  font-size: clamp(1.05rem, 2vw, 1.35rem);
  color: rgba(240,234,216,0.7);
  line-height: 1.6;
  max-width: 560px;
  margin-bottom: 3rem;
  opacity: 0;
  animation: v2fadeUp 0.8s var(--v2-ease-out) 0.65s forwards;
}
.v2-hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: v2fadeUp 0.8s var(--v2-ease-out) 0.8s forwards;
}
.v2-hero-scroll-hint {
  position: absolute;
  bottom: 9rem;
  right: 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  z-index: 10;
  opacity: 0;
  animation: v2fadeIn 1s var(--v2-ease) 1.5s forwards;
}
.v2-scroll-line {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, var(--v2-gold), transparent);
  animation: v2scrollLine 2s ease infinite;
}
@keyframes v2scrollLine {
  0% { transform: scaleY(0); transform-origin: top; }
  50% { transform: scaleY(1); transform-origin: top; }
  51% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
.v2-hero-scroll-hint span {
  font-family: var(--v2-font-display);
  font-size: 0.55rem;
  letter-spacing: 3px;
  color: var(--v2-muted);
  writing-mode: vertical-rl;
}
@keyframes v2fadeIn { to { opacity: 1; } }

@media (max-width: 900px) {
  .v2-hero-scroll-hint { display: none; }
}

@media (max-width: 768px) {
  .v2-hero {
    min-height: auto;
    padding-top: 2rem;
  }
  .v2-hero-content {
    padding: 6.5rem 1.25rem 4rem;
    text-align: left;
  }
  .v2-hero-badge {
    margin-bottom: 1.5rem;
    font-size: 0.6rem;
    padding: 0.35rem 0.85rem;
  }
  .v2-hero-title {
    font-size: clamp(2.1rem, 8.5vw, 3rem);
    letter-spacing: -1px;
    margin-bottom: 1.25rem;
  }
  .v2-title-stroke {
    -webkit-text-stroke: 1px var(--v2-white);
  }
  .v2-hero-sub {
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 320px;
    margin-bottom: 2rem;
  }
  .v2-hero-actions {
    flex-direction: column;
    gap: 0.85rem;
    width: 100%;
  }
  .v2-hero-actions .v2-btn {
    width: 100%;
    min-height: 52px;
    justify-content: center;
  }
}
</style>
