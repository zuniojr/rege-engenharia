---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Differentials from '../components/Differentials.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
---

<Layout 
  title="Regê Engenharia | Projetos, Construção e Regularização de Obras" 
  description="A Regê Engenharia é especializada em gerenciamento de obras chave na mão, projetos arquitetônicos e estruturais e regularização completa de imóveis."
>
  <Header />
  <main>
    <Hero />
    <Differentials />
    <Gallery />
    <Testimonials />
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
