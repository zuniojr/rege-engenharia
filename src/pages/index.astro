---
import Layout from '../layouts/Layout.astro';
import V2Nav from '../components/v2/V2Nav.astro';
import V2Hero from '../components/v2/V2Hero.astro';
import V2About from '../components/v2/V2About.astro';
import V2Services from '../components/v2/V2Services.astro';
import V2QuoteBanner from '../components/v2/V2QuoteBanner.astro';
import V2Portfolio from '../components/v2/V2Portfolio.astro';
import V2Testimonials from '../components/v2/V2Testimonials.astro';
import V2CtaSection from '../components/v2/V2CtaSection.astro';
import V2Footer from '../components/v2/V2Footer.astro';
import FloatingCTA from '../components/v2/FloatingCTA.astro';
import '../styles/v2.css';
---

<Layout
  title="Regê Engenharia | Projetos, Construção e Regularização de Obras"
  description="A Regê Engenharia é especializada em gerenciamento de obras chave na mão, projetos arquitetônicos e estruturais e regularização completa de imóveis em Navegantes - SC."
  showHeader={false}
  showFooter={false}
>
  <V2Nav />
  <V2Hero />
  <V2About />
  <V2Services />
  <V2QuoteBanner />
  <V2Portfolio />
  <V2Testimonials />
  <V2CtaSection />
  <V2Footer />
  <FloatingCTA />
</Layout>

<script>
  // Scroll reveal
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.v2-reveal').forEach(el => revealObserver.observe(el));
</script>
