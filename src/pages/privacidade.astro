---
import Layout from '../layouts/Layout.astro';
import V2Nav from '../components/v2/V2Nav.astro';
import V2Footer from '../components/v2/V2Footer.astro';
import FloatingCTA from '../components/v2/FloatingCTA.astro';
import '../styles/v2.css';
---

<Layout 
  title="Política de Privacidade | Regê Engenharia" 
  description="Saiba como a Regê Engenharia coleta, usa e protege seus dados pessoais, em conformidade com a LGPD (Lei nº 13.709/2018)."
  showHeader={false}
  showFooter={false}
>
  <V2Nav />

  <main class="pp-page">
    <!-- HERO -->
    <header class="pp-hero">
      <div class="v2-container">
        <span class="v2-eyebrow">INSTITUCIONAL</span>
        <h1>Política de Privacidade</h1>
        <p class="pp-hero-sub">Última atualização: 15 de Julho de 2026</p>
        <p class="pp-hero-desc">
          A Regê Engenharia valoriza e respeita a sua privacidade. Este documento explica, de forma clara e objetiva, 
          como tratamos seus dados pessoais em conformidade com a 
          <strong>Lei Geral de Proteção de Dados (LGPD — Lei nº 13.709/2018)</strong>.
        </p>
      </div>
    </header>

    <!-- CONTENT -->
    <section class="pp-content">
      <div class="v2-container pp-grid">
        
        <aside class="pp-sidebar">
          <nav class="pp-toc">
            <a href="#controlador" class="active">1. Controlador dos Dados</a>
            <a href="#coleta">2. Dados Coletados</a>
            <a href="#finalidade">3. Finalidade do Tratamento</a>
            <a href="#base-legal">4. Base Legal</a>
            <a href="#compartilhamento">5. Compartilhamento</a>
            <a href="#retencao">6. Retenção e Exclusão</a>
            <a href="#direitos">7. Seus Direitos</a>
            <a href="#cookies">8. Cookies</a>
            <a href="#seguranca">9. Segurança</a>
            <a href="#contato">10. Contato / DPO</a>
          </nav>
        </aside>

        <article class="pp-article">

          <!-- 1 -->
          <div class="pp-section" id="controlador">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h2>1. Controlador dos Dados</h2>
            <p>O <strong>controlador</strong> responsável pelo tratamento dos dados pessoais coletados por meio deste site é:</p>
            <div class="pp-card">
              <div class="pp-card-row">
                <span class="pp-card-label">Empresa</span>
                <span>Regê Engenharia</span>
              </div>
              <div class="pp-card-row">
                <span class="pp-card-label">Atuação</span>
                <span>Litoral de Santa Catarina e Região</span>
              </div>
              <div class="pp-card-row">
                <span class="pp-card-label">E-mail</span>
                <a href="mailto:contato@regeengenharia.com.br">contato@regeengenharia.com.br</a>
              </div>
              <div class="pp-card-row">
                <span class="pp-card-label">Telefone</span>
                <a href="https://bitlybr.net/rege" target="_blank" rel="noopener noreferrer" class="pp-whatsapp-btn">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  <span>WhatsApp</span>
                </a>
              </div>
            </div>
          </div>

          <!-- 2 -->
          <div class="pp-section" id="coleta">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </div>
            <h2>2. Dados Coletados</h2>
            <p>Coletamos apenas os dados estritamente necessários para as finalidades descritas nesta política. Os dados podem ser fornecidos diretamente por você ou coletados automaticamente durante a navegação:</p>
            <p><strong>Fornecidos por você:</strong></p>
            <ul>
              <li>Nome completo;</li>
              <li>Endereço de e-mail;</li>
              <li>Número de telefone / WhatsApp;</li>
              <li>Mensagem ou descrição do projeto (quando enviada via formulário de contato).</li>
            </ul>
            <p><strong>Coletados automaticamente:</strong></p>
            <ul>
              <li>Endereço IP e dados de acesso (data, hora, páginas visitadas);</li>
              <li>Tipo de dispositivo, navegador e sistema operacional;</li>
              <li>Origem do acesso (busca orgânica, redes sociais, links diretos);</li>
              <li>Dados de cookies e tecnologias similares (ver seção 8).</li>
            </ul>
          </div>

          <!-- 3 -->
          <div class="pp-section" id="finalidade">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </div>
            <h2>3. Finalidade do Tratamento</h2>
            <p>Utilizamos seus dados para as seguintes finalidades:</p>
            <ul>
              <li><strong>Atendimento ao cliente</strong> — responder solicitações de orçamento, consultas técnicas e mensagens recebidas por formulário ou WhatsApp;</li>
              <li><strong>Comunicação comercial</strong> — envio de informações sobre serviços, projetos concluídos e novidades, sempre com opção de cancelamento (opt-out);</li>
              <li><strong>Melhoria do site</strong> — análise de tráfego e comportamento de navegação para aprimorar a experiência do usuário;</li>
              <li><strong>Cumprimento de obrigações legais</strong> — quando exigido pela legislação aplicável.</li>
            </ul>
            <div class="pp-alert pp-alert-info">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>Não utilizamos seus dados para fins de <strong>marketing de terceiros</strong>, venda de listas ou criação de perfis automatizados sem consentimento explícito.</span>
            </div>
          </div>

          <!-- 4 -->
          <div class="pp-section" id="base-legal">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h2>4. Base Legal (LGPD)</h2>
            <p>Todo tratamento de dados realizado pela Regê Engenharia é fundamentado em ao menos uma das bases legais previstas no art. 7º da LGPD:</p>
            <ul>
              <li><strong>Consentimento</strong> (art. 7º, I) — quando você envia um formulário ou aceita o recebimento de comunicações;</li>
              <li><strong>Execução de contrato</strong> (art. 7º, V) — quando o tratamento é necessário para cumprir um contrato de prestação de serviços celebrado com você;</li>
              <li><strong>Legítimo interesse</strong> (art. 7º, IX) — para análise de tráfego e melhoria contínua do site, desde que não prevaleçam seus direitos e liberdades fundamentais;</li>
              <li><strong>Obrigação legal</strong> (art. 7º, II) — quando exigido por legislação tributária, trabalhista ou regulatória aplicável.</li>
            </ul>
          </div>

          <!-- 5 -->
          <div class="pp-section" id="compartilhamento">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </div>
            <h2>5. Compartilhamento de Dados</h2>
            <p>A Regê Engenharia <strong>não vende, aluga nem comercializa</strong> seus dados pessoais. O compartilhamento é limitado e ocorre somente nas seguintes situações:</p>
            <ul>
              <li><strong>Ferramentas de análise</strong> — Google Analytics (dados anonimizados de navegação);</li>
              <li><strong>Plataformas de comunicação</strong> — WhatsApp Business e e-mail para resposta a solicitações;</li>
              <li><strong>Prestadores de serviço técnico</strong> — hospedagem (Vercel) e plataformas de desenvolvimento, sob obrigação contratual de confidencialidade;</li>
              <li><strong>Autoridades competentes</strong> — quando obrigados por lei, ordem judicial ou processo administrativo.</li>
            </ul>
            <div class="pp-alert pp-alert-warning">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <span>Todos os parceiros e prestadores de serviços que eventualmente acessam seus dados são contratualmente obrigados a adotar medidas de segurança equivalentes às nossas.</span>
            </div>
          </div>

          <!-- 6 -->
          <div class="pp-section" id="retencao">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            </div>
            <h2>6. Retenção e Exclusão</h2>
            <p>Mantemos seus dados pessoais apenas pelo tempo necessário para cumprir as finalidades descritas nesta política ou conforme exigido por lei:</p>
            <ul>
              <li><strong>Dados de contato e orçamento</strong> — até 5 anos após o encerramento do relacionamento comercial, por exigência fiscal;</li>
              <li><strong>Dados de navegação e cookies analíticos</strong> — até 26 meses;</li>
              <li><strong>Comunicações de marketing</strong> — enquanto você não solicitar o cancelamento (opt-out).</li>
            </ul>
            <p>Após o prazo aplicável, os dados são excluídos de forma segura ou anonimizados, impossibilitando qualquer associação à sua pessoa.</p>
          </div>

          <!-- 7 -->
          <div class="pp-section" id="direitos">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 15 11 17 15 13"/></svg>
            </div>
            <h2>7. Seus Direitos (LGPD, art. 18)</h2>
            <p>Como titular dos dados, você possui os seguintes direitos, exercíveis a qualquer momento mediante solicitação ao nosso canal de atendimento:</p>
            <ul>
              <li><strong>Confirmação e acesso</strong> — saber se tratamos seus dados e obter uma cópia;</li>
              <li><strong>Correção</strong> — atualizar dados incompletos, inexatos ou desatualizados;</li>
              <li><strong>Anonimização, bloqueio ou eliminação</strong> — para dados tratados com base no consentimento ou sem necessidade comprovada;</li>
              <li><strong>Portabilidade</strong> — receber seus dados em formato estruturado para outro fornecedor de serviço;</li>
              <li><strong>Revogação do consentimento</strong> — a qualquer momento, sem prejuízo da legalidade dos tratamentos realizados anteriormente;</li>
              <li><strong>Oposição</strong> — contestar o tratamento realizado com base em legítimo interesse;</li>
              <li><strong>Reclamação à ANPD</strong> — você pode registrar reclamações perante a Autoridade Nacional de Proteção de Dados.</li>
            </ul>
            <div class="pp-alert pp-alert-info">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>Responderemos às solicitações relacionadas aos seus direitos em até <strong>15 dias úteis</strong>, conforme previsto na LGPD.</span>
            </div>
          </div>

          <!-- 8 -->
          <div class="pp-section" id="cookies">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>
            </div>
            <h2>8. Cookies e Tecnologias Similares</h2>
            <p>Utilizamos cookies para melhorar a experiência de navegação, analisar o tráfego do site e personalizar conteúdo. Os tipos de cookies utilizados são:</p>
            <ul>
              <li><strong>Cookies essenciais</strong> — necessários para o funcionamento básico do site (sessão, segurança). Não podem ser desativados;</li>
              <li><strong>Cookies analíticos</strong> — coletam informações anônimas sobre o uso do site (Google Analytics). Podem ser recusados;</li>
              <li><strong>Cookies de preferência</strong> — lembram suas escolhas de navegação para uma experiência personalizada.</li>
            </ul>
            <p>Você pode gerenciar ou desativar cookies nas configurações do seu navegador a qualquer momento. A desativação de cookies analíticos não afeta o funcionamento do site.</p>
          </div>

          <!-- 9 -->
          <div class="pp-section" id="seguranca">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h2>9. Segurança das Informações</h2>
            <p>Adotamos medidas técnicas e organizacionais adequadas para proteger seus dados contra acesso não autorizado, perda, alteração ou destruição, incluindo:</p>
            <ul>
              <li>Comunicação criptografada via protocolo <strong>HTTPS/TLS</strong>;</li>
              <li>Hospedagem em infraestrutura segura com controle de acesso restrito (Vercel);</li>
              <li>Acesso aos dados limitado apenas aos colaboradores e prestadores com necessidade operacional justificada;</li>
              <li>Revisão periódica de práticas de segurança e conformidade.</li>
            </ul>
            <p>Em caso de incidente de segurança que possa afetar seus dados, notificaremos você e a ANPD nos prazos e formas previstos na legislação vigente.</p>
          </div>

          <!-- 10 -->
          <div class="pp-section" id="contato">
            <div class="pp-section-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h2>10. Contato e Encarregado de Dados (DPO)</h2>
            <p>Para exercer seus direitos, esclarecer dúvidas sobre esta política ou reportar qualquer preocupação relacionada ao tratamento dos seus dados pessoais, entre em contato com nosso encarregado (DPO):</p>
            <p class="pp-highlight">
              <a href="mailto:contato@regeengenharia.com.br">contato@regeengenharia.com.br</a> ou pelo telefone <a href="tel:+5547992184100">(47) 99218-4100</a>.
            </p>
            <p>Esta política poderá ser atualizada periodicamente para refletir mudanças em nossas práticas ou na legislação aplicável. Recomendamos a revisão regular desta página. A data da última atualização está indicada no topo deste documento.</p>
            <div class="pp-cta-row">
              <a href="https://bitlybr.net/rege" target="_blank" rel="noopener noreferrer" class="pp-cta-btn">
                Falar com Nossa Equipe
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="/termos" class="pp-cta-link">Ver Termos de Uso</a>
            </div>
          </div>

        </article>
      </div>
    </section>
  </main>

  <V2Footer />
  <FloatingCTA />
</Layout>

<style>
.pp-page {
  background: var(--v2-dark);
  color: var(--v2-white);
  padding-bottom: 6rem;
}

/* HERO */
.pp-hero {
  padding: 12rem 0 5rem;
  border-bottom: 1px solid var(--v2-border);
  background: linear-gradient(160deg, var(--v2-dark-2) 0%, var(--v2-dark) 100%);
  position: relative;
  overflow: hidden;
}
.pp-hero::before {
  content: '';
  position: absolute;
  top: -80px;
  left: -80px;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 160, 80, 0.05) 0%, transparent 70%);
  pointer-events: none;
}
.pp-hero h1 {
  font-family: var(--v2-font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -1.5px;
  color: var(--v2-white);
  margin: 0.5rem 0 1rem;
}
.pp-hero-sub {
  font-family: var(--v2-font-serif);
  font-style: italic;
  color: var(--v2-muted);
  font-size: 1rem;
  margin: 0 0 1.25rem;
}
.pp-hero-desc {
  font-family: var(--v2-font-body);
  font-size: 1rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.6);
  max-width: 680px;
  margin: 0;
}
.pp-hero-desc strong {
  color: var(--v2-gold);
}

/* CONTENT LAYOUT */
.pp-content { padding: 5rem 0; }
.pp-grid {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 4rem;
}

/* SIDEBAR / TOC */
.pp-sidebar {
  position: sticky;
  top: 7rem;
  height: fit-content;
}
.pp-toc {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  border-left: 2px solid var(--v2-border);
  padding-left: 1.5rem;
}
.pp-toc a {
  font-family: var(--v2-font-display);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--v2-muted);
  text-decoration: none;
  transition: all 0.25s var(--v2-ease);
  line-height: 1.4;
}
.pp-toc a:hover,
.pp-toc a.active {
  color: var(--v2-gold);
  padding-left: 4px;
}

/* ARTICLE */
.pp-article { max-width: 750px; }
.pp-section {
  margin-bottom: 4.5rem;
  padding-bottom: 4.5rem;
  border-bottom: 1px solid var(--v2-border);
}
.pp-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

/* SECTION ICON */
.pp-section-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: rgba(200, 160, 80, 0.1);
  border: 1px solid rgba(200, 160, 80, 0.2);
  border-radius: 8px;
  color: var(--v2-gold);
  margin-bottom: 1.25rem;
}

.pp-section h2 {
  font-family: var(--v2-font-display);
  font-size: 1.4rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -0.5px;
  color: var(--v2-white);
  margin: 0 0 1.5rem;
}
.pp-section p {
  font-family: var(--v2-font-body);
  font-size: 0.95rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.7);
  margin: 0 0 1.25rem;
}
.pp-section strong { color: var(--v2-white); font-weight: 700; }
.pp-section ul {
  margin: 0 0 1.5rem 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  list-style: none;
}
.pp-section li {
  font-family: var(--v2-font-body);
  font-size: 0.93rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.65);
  padding-left: 1.25rem;
  position: relative;
