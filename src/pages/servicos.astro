---
import Layout from '../layouts/Layout.astro';
import V2Nav from '../components/v2/V2Nav.astro';
import V2Footer from '../components/v2/V2Footer.astro';
import V2CtaSection from '../components/v2/V2CtaSection.astro';
import FloatingCTA from '../components/v2/FloatingCTA.astro';
import '../styles/v2.css';
---

<Layout
  title="Serviços | Regê Engenharia — Projetos, Construção e Regularização"
  description="Conheça os serviços da Regê Engenharia: gestão chave na mão, projetos personalizados, aprovações, regularizações e execução de obras em Navegantes - SC."
  showHeader={false}
  showFooter={false}
>
  <V2Nav />

  <!-- PAGE HERO -->
  <section class="svc-hero">
    <div class="svc-hero-bg">
      <img src="/images/hero-rege.png" alt="Obra Regê Engenharia" />
      <div class="svc-hero-overlay"></div>
    </div>
    <div class="svc-hero-content v2-container">
      <div class="svc-hero-badge">
        <span class="v2-badge-dot"></span>
        NOSSOS SERVIÇOS
      </div>
      <h1 class="svc-hero-title">
        <span class="svc-title-line" style="animation-delay:0.3s">SOLUÇÕES</span>
        <span class="svc-title-line svc-title-accent" style="animation-delay:0.45s">COMPLETAS</span>
        <span class="svc-title-line svc-title-stroke" style="animation-delay:0.6s">EM ENGENHARIA.</span>
      </h1>
      <p class="svc-hero-sub">
        Da concepção à entrega das chaves — cada serviço
        é pensado para garantir excelência e tranquilidade.
      </p>
      <nav class="svc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Início</a>
        <span class="svc-breadcrumb-sep">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span>Serviços</span>
      </nav>
    </div>
  </section>

  <!-- SERVIÇOS DETALHADOS -->
  <section class="svc-detail">
    <div class="v2-container">
      <div class="v2-section-header v2-reveal" style="text-align:center; margin-bottom:5rem;">
        <span class="v2-eyebrow">CONFIANÇA E EXCELÊNCIA</span>
        <h2 class="v2-section-title">Serviços &amp;<br /><em>Soluções</em></h2>
      </div>

      <!-- SERVIÇO 01 -->
      <div class="svc-block v2-reveal" id="chave-na-mao">
        <div class="svc-block-img">
          <div class="svc-block-frame">
            <img src="/images/obra-residencial.png" alt="Gestão Chave na Mão" loading="lazy" />
          </div>
          <div class="svc-block-num">01</div>
        </div>
        <div class="svc-block-text">
          <div class="svc-block-tag">TURNKEY</div>
          <h3>Da Concepção à Chave na Mão</h3>
          <p class="svc-block-lead">Cuidamos de absolutamente todo o processo da sua obra, desde os primeiros esboços até a entrega final das chaves.</p>
          <p>Nosso modelo <strong>turnkey (chave na mão)</strong> é a solução ideal para quem deseja construir sem preocupações. Assumimos a responsabilidade completa do projeto: estudos preliminares, modelagem 3D, orçamento executivo detalhado, execução técnica no canteiro, gestão de fornecedores e a entrega das chaves com limpeza pós-obra.</p>
          <ul class="svc-block-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Estudos preliminares e viabilidade
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Modelagem de projetos integrados
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Orçamento executivo detalhado
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Execução técnica e gestão de canteiro
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Limpeza pós-obra e entrega das chaves
            </li>
          </ul>
          <a href="https://bitlybr.net/rege" class="v2-btn v2-btn-primary" target="_blank" rel="noopener noreferrer">
            <span>Solicitar Orçamento</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- SERVIÇO 02 -->
      <div class="svc-block svc-block-reverse v2-reveal" id="projetos">
        <div class="svc-block-img">
          <div class="svc-block-frame">
            <img src="/images/projeto-arquitetonico.png" alt="Projetos Personalizados" loading="lazy" />
          </div>
          <div class="svc-block-num">02</div>
        </div>
        <div class="svc-block-text">
          <div class="svc-block-tag">PROJETOS</div>
          <h3>Projetos Personalizados</h3>
          <p class="svc-block-lead">Projetos de arquitetura, design de interiores, cálculo estrutural e instalações sob medida para o seu estilo de vida.</p>
          <p>Cada projeto é único. Desenvolvemos soluções arquitetônicas que refletem a personalidade e as necessidades de cada cliente, utilizando tecnologia de ponta para modelagem e visualização. Nossos projetos são integrados, contemplando todas as disciplinas necessárias para uma construção eficiente.</p>
          <ul class="svc-block-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Projeto arquitetônico completo
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Design de interiores
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Projeto estrutural e cálculo
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Projetos de instalações (elétrica, hidráulica, etc.)
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Modelagem 3D e renderização
            </li>
          </ul>
          <a href="https://bitlybr.net/rege" class="v2-btn v2-btn-primary" target="_blank" rel="noopener noreferrer">
            <span>Falar sobre meu Projeto</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- SERVIÇO 03 -->
      <div class="svc-block v2-reveal" id="regularizacao">
        <div class="svc-block-img">
          <div class="svc-block-frame">
            <img src="/images/regularizacao.png" alt="Aprovações e Regularizações" loading="lazy" />
          </div>
          <div class="svc-block-num">03</div>
        </div>
        <div class="svc-block-text">
          <div class="svc-block-tag">LEGAL</div>
          <h3>Aprovações e Regularizações</h3>
          <p class="svc-block-lead">Aprovação junto à Prefeitura, licenciamento do Corpo de Bombeiros, averbações e regularização completa de imóveis.</p>
          <p>A burocracia não precisa ser um obstáculo. Nossa equipe conhece profundamente os trâmites legais e normativos necessários para regularizar seu imóvel ou obter todas as aprovações para sua nova construção. Tratamos de toda a documentação para que você tenha total segurança jurídica.</p>
          <ul class="svc-block-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Aprovação de projetos na Prefeitura
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Licenciamento do Corpo de Bombeiros
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Averbação de construção
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Regularização de imóveis
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Habite-se e certidões
            </li>
          </ul>
          <a href="https://bitlybr.net/rege" class="v2-btn v2-btn-primary" target="_blank" rel="noopener noreferrer">
            <span>Regularizar meu Imóvel</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- SERVIÇO 04 -->
      <div class="svc-block svc-block-reverse v2-reveal" id="execucao">
        <div class="svc-block-img">
          <div class="svc-block-frame">
            <img src="/images/obra-comercial.png" alt="Execução e Gestão de Obras" loading="lazy" />
          </div>
          <div class="svc-block-num">04</div>
        </div>
        <div class="svc-block-text">
          <div class="svc-block-tag">EXECUÇÃO</div>
          <h3>Execução &amp; Gestão de Obras</h3>
          <p class="svc-block-lead">Gestão técnica rigorosa do canteiro com fidelidade ao projeto, prazos cumpridos e controle financeiro transparente.</p>
          <p>Nossa gestão de obras combina rigor técnico com eficiência operacional. Controlamos cada aspecto da execução — cronograma, qualidade dos materiais, segurança do canteiro e custos — garantindo que sua obra seja entregue dentro do prazo e do orçamento, sem comprometer a qualidade.</p>
          <ul class="svc-block-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Gestão técnica de canteiro
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Controle de cronograma e prazos
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Relatórios financeiros periódicos
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Fiscalização de qualidade e segurança
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              Gestão de fornecedores e subempreiteiros
            </li>
          </ul>
          <a href="https://bitlybr.net/rege" class="v2-btn v2-btn-primary" target="_blank" rel="noopener noreferrer">
            <span>Falar com a Equipe</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESSO DE TRABALHO -->
  <section class="svc-process">
    <div class="svc-process-bg" aria-hidden="true"></div>
    <div class="v2-container">
      <div class="v2-section-header v2-reveal" style="text-align:center;">
        <span class="v2-eyebrow v2-eyebrow-light">METODOLOGIA</span>
        <h2 class="v2-section-title v2-light">Como<br /><em>Trabalhamos</em></h2>
      </div>
      <div class="svc-process-grid">
        <div class="svc-step v2-reveal">
          <div class="svc-step-line" aria-hidden="true"></div>
          <div class="svc-step-dot"></div>
          <div class="svc-step-content">
            <span class="svc-step-num">01</span>
            <h4>Consulta Inicial</h4>
            <p>Entendemos suas necessidades, estilo de vida, objetivos e orçamento disponível. Sem compromisso.</p>
          </div>
        </div>
        <div class="svc-step v2-reveal v2-reveal-delay-1">
          <div class="svc-step-line" aria-hidden="true"></div>
          <div class="svc-step-dot"></div>
          <div class="svc-step-content">
            <span class="svc-step-num">02</span>
            <h4>Estudo & Projeto</h4>
            <p>Desenvolvemos o estudo de viabilidade, projeto arquitetônico e orçamento executivo detalhado.</p>
          </div>
        </div>
        <div class="svc-step v2-reveal v2-reveal-delay-2">
          <div class="svc-step-line" aria-hidden="true"></div>
          <div class="svc-step-dot"></div>
          <div class="svc-step-content">
            <span class="svc-step-num">03</span>
            <h4>Aprovações</h4>
            <p>Cuidamos de toda a burocracia: aprovação na prefeitura, bombeiros, licenças e alvarás.</p>
          </div>
        </div>
        <div class="svc-step v2-reveal">
          <div class="svc-step-line" aria-hidden="true"></div>
          <div class="svc-step-dot"></div>
          <div class="svc-step-content">
            <span class="svc-step-num">04</span>
            <h4>Execução</h4>
            <p>Início da obra com gestão rigorosa de cronograma, qualidade, segurança e custos.</p>
          </div>
        </div>
        <div class="svc-step v2-reveal v2-reveal-delay-1">
          <div class="svc-step-line" aria-hidden="true"></div>
          <div class="svc-step-dot"></div>
          <div class="svc-step-content">
            <span class="svc-step-num">05</span>
            <h4>Acompanhamento</h4>
            <p>Relatórios periódicos, fotos e atualizações constantes sobre o andamento da sua obra.</p>
          </div>
        </div>
        <div class="svc-step v2-reveal v2-reveal-delay-2">
          <div class="svc-step-line" aria-hidden="true"></div>
          <div class="svc-step-dot svc-step-dot-final"></div>
          <div class="svc-step-content">
            <span class="svc-step-num">06</span>
            <h4>Entrega das Chaves</h4>
            <p>Vistoria final, limpeza pós-obra e entrega das chaves com documentação completa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="svc-faq">
    <div class="v2-container">
      <div class="svc-faq-grid">
        <div class="svc-faq-header v2-reveal">
          <span class="v2-eyebrow">DÚVIDAS</span>
          <h2 class="v2-section-title">Perguntas<br /><em>Frequentes</em></h2>
          <div class="v2-title-underline"></div>
          <p class="svc-faq-intro">Tire suas principais dúvidas sobre nossos serviços. Se precisar de mais informações, estamos à disposição.</p>
          <a href="https://bitlybr.net/rege" class="v2-btn v2-btn-primary" target="_blank" rel="noopener noreferrer">
            <span>Falar no WhatsApp</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="svc-faq-list v2-reveal v2-reveal-delay-1">
          <details class="svc-faq-item">
            <summary>
              O que é o modelo chave na mão (turnkey)?
              <svg class="svc-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p>É um modelo de construção onde a Regê Engenharia assume a responsabilidade total do projeto, desde a concepção até a entrega final das chaves. O cliente participa das decisões importantes, mas não precisa se preocupar com a gestão do dia a dia da obra.</p>
          </details>
          <details class="svc-faq-item">
            <summary>
              Vocês fazem obras residenciais e comerciais?
              <svg class="svc-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p>Sim! Atuamos em obras residenciais (casas, sobrados, edifícios) e comerciais (lojas, galpões, escritórios). Cada projeto recebe atenção personalizada de acordo com suas necessidades específicas.</p>
          </details>
          <details class="svc-faq-item">
            <summary>
              Qual a área de atuação da Regê Engenharia?
              <svg class="svc-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p>Nossa sede fica em Navegantes - SC e atendemos toda a região do Vale do Itajaí e litoral catarinense, incluindo cidades como Itajaí, Balneário Camboriú, Penha, Piçarras e região.</p>
          </details>
          <details class="svc-faq-item">
            <summary>
              Como funciona o controle financeiro das obras?
              <svg class="svc-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p>Trabalhamos com orçamento executivo detalhado desde o primeiro dia. O cliente recebe relatórios financeiros periódicos com todos os custos discriminados, garantindo total transparência e previsibilidade.</p>
          </details>
          <details class="svc-faq-item">
            <summary>
              Posso contratar apenas o projeto, sem a execução?
              <svg class="svc-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p>Sim, nossos serviços são modulares. Você pode contratar apenas o projeto arquitetônico, apenas a regularização, ou o pacote completo chave na mão. Adaptamos a proposta às suas necessidades.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <V2CtaSection />
  <V2Footer />
  <FloatingCTA />
</Layout>

<style>
/* ============================
   SERVIÇOS - PAGE HERO
   ============================ */
.svc-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background: var(--v2-dark);
}
.svc-hero-bg {
  position: absolute;
  inset: 0;
}
.svc-hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.85;
  filter: contrast(1.05);
}
.svc-hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(8,14,23,0.88) 30%, rgba(8,14,23,0.15) 100%),
    linear-gradient(to top, rgba(8,14,23,0.75) 0%, transparent 60%);
}
.svc-hero-content {
  position: relative;
  z-index: 10;
  padding: 12rem 1.5rem 5rem;
}
.svc-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--v2-gold);
  border: 1px solid rgba(201,168,76,0.3);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  margin-bottom: 2rem;
  opacity: 0;
  animation: svcFadeUp 0.8s var(--v2-ease-out) 0.1s forwards;
}
.svc-hero-title {
  display: flex;
  flex-direction: column;
  font-family: var(--v2-font-display);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2px;
  text-transform: uppercase;
  margin: 0 0 1.5rem;
  color: var(--v2-white);
}
.svc-title-line {
  opacity: 0;
  transform: translateY(30px);
  animation: svcFadeUp 0.8s var(--v2-ease-out) forwards;
}
.svc-title-accent { color: var(--v2-gold); }
.svc-title-stroke {
  -webkit-text-stroke: 2px var(--v2-white);
  color: transparent;
}
.svc-hero-sub {
  font-family: var(--v2-font-serif);
  font-style: italic;
  font-size: clamp(1rem, 1.8vw, 1.25rem);
  color: rgba(240,234,216,0.7);
  line-height: 1.6;
  max-width: 520px;
