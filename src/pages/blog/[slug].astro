---
import Layout from '../../layouts/Layout.astro';
import V2Nav from '../../components/v2/V2Nav.astro';
import V2Footer from '../../components/v2/V2Footer.astro';
import V2CtaSection from '../../components/v2/V2CtaSection.astro';
import FloatingCTA from '../../components/v2/FloatingCTA.astro';
import { blogPosts } from '../../data/blogPosts.js';
import '../../styles/v2.css';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const relatedPosts = blogPosts.filter(p => p.slug !== post.slug).slice(0, 3);
---

<Layout
  title={`${post.title} | Blog Regê Engenharia`}
  description={post.excerpt}
  showHeader={false}
  showFooter={false}
>
  <V2Nav />

  <!-- ARTICLE HERO -->
  <section class="sp-hero">
    <div class="sp-hero-bg">
      <img src={post.image} alt={post.imageAlt} />
      <div class="sp-hero-overlay"></div>
    </div>
    <div class="sp-hero-content v2-container">
      <div class="sp-hero-badge">
        <span class="v2-badge-dot"></span>
        {post.tag}
      </div>
      <h1 class="sp-hero-title">
        {post.title}
      </h1>
      <div class="sp-hero-meta">
        <span class="sp-meta-date">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {post.date}
        </span>
        <span class="sp-meta-sep">•</span>
        <span class="sp-meta-read">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {post.readTime}
        </span>
      </div>
      <nav class="sp-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Início</a>
        <span class="sp-breadcrumb-sep">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <a href="/blog">Blog</a>
        <span class="sp-breadcrumb-sep">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span>{post.tag.charAt(0) + post.tag.slice(1).toLowerCase()}</span>
      </nav>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="sp-body">
    <div class="sp-body-accent-line"></div>
    <div class="v2-container">
      <div class="sp-layout">
        
        <!-- Main Content -->
        <article class="sp-article v2-reveal">
          {post.content.map((block) => {
            if (block.type === 'paragraph') {
              return <p>{block.text}</p>;
            }
            if (block.type === 'heading') {
              return <h2>{block.text}</h2>;
            }
            if (block.type === 'list') {
              return (
                <ul>
                  {block.items.map((item) => <li>{item}</li>)}
                </ul>
              );
            }
            if (block.type === 'quote') {
              return (
                <blockquote>
                  <p>{block.text}</p>
                </blockquote>
              );
            }
          })}

          <!-- Share / Tags -->
          <div class="sp-article-footer">
            <div class="sp-tags">
              <span class="sp-tag-label">Tags:</span>
              <span class="sp-tag">{post.tag}</span>
            </div>
            <div class="sp-share">
              <span class="sp-share-label">Compartilhar:</span>
              <a href={`https://wa.me/?text=${encodeURIComponent(post.title + ' - https://rege-engenharia.vercel.app/blog/' + post.slug)}`} target="_blank" rel="noopener noreferrer" class="sp-share-btn" aria-label="Compartilhar no WhatsApp">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://rege-engenharia.vercel.app/blog/' + post.slug)}`} target="_blank" rel="noopener noreferrer" class="sp-share-btn" aria-label="Compartilhar no LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="sp-sidebar v2-reveal v2-reveal-delay-1">
          <div class="sp-sidebar-card">
            <h4 class="sp-sidebar-title">Sobre a Regê</h4>
            <p>Construtora e engenharia civil especializada no litoral de Santa Catarina. Construímos com qualidade, transparência e pontualidade.</p>
            <a href="/sobre" class="sp-sidebar-link">Conheça nossa história →</a>
          </div>
          <div class="sp-sidebar-card sp-sidebar-cta">
            <span class="sp-sidebar-cta-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <h4>Precisa de ajuda?</h4>
            <p>Fale com nossos engenheiros e tire suas dúvidas sobre o seu projeto.</p>
            <a href="https://bitlybr.net/rege" target="_blank" rel="noopener noreferrer" class="v2-btn v2-btn-primary sp-sidebar-btn">
              <span>Falar com a Equipe</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- RELATED POSTS -->
  <section class="sp-related">
    <div class="v2-container">
      <div class="sp-related-header v2-reveal">
        <span class="v2-eyebrow">CONTINUE LENDO</span>
        <h2 class="v2-section-title">Artigos <em>relacionados</em></h2>
      </div>
      <div class="sp-related-grid">
        {relatedPosts.map((rPost, i) => (
          <a href={`/blog/${rPost.slug}`} target="_blank" rel="noopener noreferrer" class={`sp-related-card v2-reveal ${i > 0 ? `v2-reveal-delay-${i}` : ''}`}>
            <div class="sp-related-card-img">
              <img src={rPost.image} alt={rPost.imageAlt} />
            </div>
            <div class="sp-related-card-content">
              <div class="blog-post-meta">
                <span class="blog-post-tag">{rPost.tag}</span>
                <span class="blog-post-date">{rPost.date}</span>
              </div>
              <h3>{rPost.title}</h3>
              <span class="sp-related-card-link">Ler artigo →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <V2CtaSection />
  <V2Footer />
  <FloatingCTA />
</Layout>

<style>
/* ============================
   SINGLE POST — HERO
   ============================ */
.sp-hero {
  position: relative;
  min-height: 75vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  background: var(--v2-dark);
}
.sp-hero-bg {
  position: absolute;
  inset: 0;
}
.sp-hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.3;
  filter: grayscale(20%) contrast(1.1);
  transform: scale(1.05);
  animation: spHeroZoom 20s ease-in-out infinite alternate;
}
@keyframes spHeroZoom {
  from { transform: scale(1.05); }
  to { transform: scale(1.12); }
}
.sp-hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(8,14,23,0.95) 30%, rgba(8,14,23,0.5) 100%),
    linear-gradient(to top, rgba(8,14,23,1) 0%, rgba(8,14,23,0.6) 30%, transparent 60%);
}
.sp-hero-content {
  position: relative;
  z-index: 10;
  padding: 0 1.5rem 5rem;
  max-width: 850px;
}
.sp-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--v2-font-display);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--v2-gold);
  border: 1px solid rgba(201,168,76,0.35);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  margin-bottom: 2rem;
  opacity: 0;
  animation: spFadeUp 0.8s var(--v2-ease-out) 0.1s forwards;
}
.sp-hero-title {
  font-family: var(--v2-font-display);
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -1.5px;
  text-transform: uppercase;
  color: var(--v2-white);
  margin: 0 0 1.5rem;
  opacity: 0;
  animation: spFadeUp 0.9s var(--v2-ease-out) 0.25s forwards;
}
.sp-hero-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: spFadeUp 0.8s var(--v2-ease-out) 0.45s forwards;
}
.sp-meta-date,
.sp-meta-read {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--v2-font-display);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 1px;
  color: rgba(240,234,216,0.6);
}
.sp-meta-date svg,
.sp-meta-read svg {
  opacity: 0.5;
}
.sp-meta-sep {
  color: rgba(255,255,255,0.2);
  font-size: 0.5rem;
}
.sp-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--v2-font-display);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  opacity: 0;
  animation: spFadeUp 0.8s var(--v2-ease-out) 0.6s forwards;
}
.sp-breadcrumb a {
  color: var(--v2-muted);
  text-decoration: none;
  transition: color 0.25s;
}
.sp-breadcrumb a:hover { color: var(--v2-gold); }
.sp-breadcrumb-sep { color: rgba(255,255,255,0.2); display: flex; }
.sp-breadcrumb > span:last-child { color: var(--v2-gold); }

@keyframes spFadeUp {
  from { opacity: 0; transform: translateY(25px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============================
   SINGLE POST — BODY / ARTICLE
   ============================ */
.sp-body {
  padding: 6rem 0 4rem;
  background: var(--v2-white);
  position: relative;
}
.sp-body-accent-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(to right, var(--v2-gold), transparent 60%);
}
.sp-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 4rem;
  align-items: start;
}

/* Article */
.sp-article {
  max-width: 100%;
}
.sp-article p {
  font-family: var(--v2-font-body);
  font-size: 1.05rem;
  line-height: 1.9;
  color: #444;
  margin: 0 0 1.75rem;
}
.sp-article h2 {
  font-family: var(--v2-font-display);
  font-size: 1.4rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -0.3px;
  color: var(--v2-dark);
  margin: 3rem 0 1.25rem;
  padding-left: 1rem;
  border-left: 3px solid var(--v2-gold);
  line-height: 1.2;
}
.sp-article ul {
  list-style: none;
  padding: 0;
  margin: 0 0 2rem;
}
.sp-article ul li {
  position: relative;
  padding-left: 1.75rem;
  font-family: var(--v2-font-body);
  font-size: 1rem;
  line-height: 1.8;
  color: #555;
  margin-bottom: 0.75rem;
}
.sp-article ul li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.65rem;
  width: 8px;
  height: 8px;
  background: var(--v2-gold);
  border-radius: 2px;
  transform: rotate(45deg);
}
.sp-article blockquote {
  margin: 2.5rem 0;
  padding: 2rem 2.5rem;
  background: linear-gradient(135deg, rgba(201,168,76,0.08) 0%, rgba(201,168,76,0.03) 100%);
  border-left: 4px solid var(--v2-gold);
  border-radius: 0 var(--v2-radius-lg) var(--v2-radius-lg) 0;
  position: relative;
}
.sp-article blockquote::before {
  content: '"';
  position: absolute;
  top: -10px;
  left: 15px;
  font-family: var(--v2-font-serif);
  font-size: 5rem;
  line-height: 1;
  color: rgba(201,168,76,0.15);
  pointer-events: none;
}
.sp-article blockquote p {
  font-family: var(--v2-font-serif);
  font-style: italic;
  font-size: 1.1rem;
  line-height: 1.7;
  color: #333;
  margin: 0;
}

/* Article Footer */
.sp-article-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 2.5rem;
  margin-top: 3rem;
  border-top: 1px solid rgba(8,14,23,0.08);
}
.sp-tags {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.sp-tag-label {
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #888;
}
.sp-tag {
  font-family: var(--v2-font-display);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--v2-gold);
  background: var(--v2-gold-muted);
  padding: 0.3rem 0.7rem;
  border-radius: 3px;
  border: 1px solid rgba(201,168,76,0.15);
}
.sp-share {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.sp-share-label {
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #888;
}
.sp-share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(8,14,23,0.05);
  color: #666;
  text-decoration: none;
  transition: all 0.3s var(--v2-ease);
}
.sp-share-btn:hover {
  background: var(--v2-gold);
  color: var(--v2-dark);
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(201,168,76,0.3);
}

/* ============================
   SIDEBAR
   ============================ */
.sp-sidebar {
  position: sticky;
  top: 6rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.sp-sidebar-card {
  background: rgba(8,14,23,0.02);
  border: 1px solid rgba(8,14,23,0.06);
  border-radius: var(--v2-radius-lg);
  padding: 2rem;
}
.sp-sidebar-title {
  font-family: var(--v2-font-display);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--v2-dark);
  margin: 0 0 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--v2-gold);
}
.sp-sidebar-card p {
  font-size: 0.9rem;
  color: #666;
  line-height: 1.7;
  margin: 0 0 1rem;
}
.sp-sidebar-link {
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--v2-gold);
  text-decoration: none;
  transition: color 0.25s;
}
.sp-sidebar-link:hover {
  color: var(--v2-dark);
}
.sp-sidebar-cta {
  background: var(--v2-dark);
  border-color: transparent;
  text-align: center;
}
.sp-sidebar-cta-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: var(--v2-gold-muted);
  color: var(--v2-gold);
  border-radius: 50%;
  margin: 0 auto 1rem;
}
.sp-sidebar-cta h4 {
  font-family: var(--v2-font-display);
  font-size: 1rem;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--v2-white);
  margin: 0 0 0.75rem;
}
.sp-sidebar-cta p {
  color: var(--v2-muted);
  font-size: 0.85rem;
}
.sp-sidebar-btn {
  width: 100%;
  justify-content: center;
  margin-top: 0.5rem;
  font-size: 0.65rem;
  padding: 0.8rem 1.5rem;
}

/* ============================
   RELATED POSTS
   ============================ */
.sp-related {
  padding: 6rem 0 4rem;
  background: #f3f1ec;
}
.sp-related-header {
  margin-bottom: 3rem;
}
.sp-related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.sp-related-card {
  background: var(--v2-white);
  border: 1px solid rgba(8,14,23,0.06);
  border-radius: var(--v2-radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: transform 0.4s var(--v2-ease), box-shadow 0.4s;
}
.sp-related-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 18px 50px rgba(8,14,23,0.1);
}
.sp-related-card-img {
  aspect-ratio: 16/10;
  overflow: hidden;
  width: 100%;
}
.sp-related-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--v2-ease);
}
.sp-related-card:hover .sp-related-card-img img {
  transform: scale(1.06);
}
.sp-related-card-content {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.sp-related-card-content h3 {
  font-family: var(--v2-font-display);
  font-size: 0.95rem;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--v2-dark);
  margin: 0 0 1.25rem;
  line-height: 1.25;
  letter-spacing: -0.2px;
  flex: 1;
}
.sp-related-card-link {
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--v2-gold);
  transition: color 0.25s;
}
.sp-related-card:hover .sp-related-card-link {
  color: var(--v2-dark);
}

/* Reuse blog meta styles */
.sp-related-card .blog-post-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
