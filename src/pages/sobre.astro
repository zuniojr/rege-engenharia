---
import Layout from '../layouts/Layout.astro';
import V2Nav from '../components/v2/V2Nav.astro';
import V2Footer from '../components/v2/V2Footer.astro';
import V2CtaSection from '../components/v2/V2CtaSection.astro';
import FloatingCTA from '../components/v2/FloatingCTA.astro';
import '../styles/v2.css';
---

<Layout
  title="Sobre | Regê Engenharia — Projetos, Construção e Regularização"
  description="Conheça a Regê Engenharia: nossa história, missão, valores e a equipe que transforma projetos em realidade desde 2016 em Navegantes - SC."
  showHeader={false}
  showFooter={false}
>
  <V2Nav />

  <!-- PAGE HERO -->
  <section class="sobre-hero">
    <div class="sobre-hero-bg">
      <img src="/images/hero-rege.png" alt="Obra Regê Engenharia" />
      <div class="sobre-hero-overlay"></div>
    </div>
    <div class="sobre-hero-content v2-container">
      <div class="sobre-hero-badge">
        <span class="v2-badge-dot"></span>
        SOBRE NÓS
      </div>
      <h1 class="sobre-hero-title">
        <span class="sobre-title-line" style="animation-delay:0.3s">ENGENHARIA COM</span>
        <span class="sobre-title-line sobre-title-accent" style="animation-delay:0.45s">PROPÓSITO</span>
        <span class="sobre-title-line sobre-title-stroke" style="animation-delay:0.6s">REAL.</span>
      </h1>
      <p class="sobre-hero-sub">
        Transformamos visões em realidade com transparência,
        excelência técnica e dedicação em cada detalhe.
      </p>
      <nav class="sobre-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Início</a>
        <span class="sobre-breadcrumb-sep">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span>Sobre</span>
      </nav>
    </div>
  </section>

  <!-- QUEM SOMOS -->
  <section class="sobre-about">
    <div class="v2-container">
      <div class="sobre-about-grid">
        <div class="sobre-about-img v2-reveal">
          <div class="v2-img-frame">
            <img src="/images/sobre-nos.png" alt="Equipe Regê Engenharia" loading="lazy" />
          </div>
          <div class="sobre-exp-badge">
            <span class="sobre-exp-label">ENGENHARIA DE<br />CONFIANÇA</span>
          </div>
        </div>
        <div class="sobre-about-text v2-reveal v2-reveal-delay-1">
          <span class="v2-eyebrow">NOSSA HISTÓRIA</span>
          <h2 class="v2-section-title">De Navegantes<br /><em>para o mundo.</em></h2>
          <div class="v2-title-underline"></div>
          <p class="sobre-about-lead">A Regê Engenharia nasceu com um propósito claro: transformar a forma como as pessoas constroem seus sonhos.</p>
          <p class="sobre-about-body">Com sede em <strong>Navegantes - SC</strong>, nos consolidamos como referência em gerenciamento de obras no modelo <strong>chave na mão (turnkey)</strong>. Nossa jornada começou com a convicção de que a engenharia pode — e deve — ser sinônimo de transparência, qualidade e respeito ao cliente.</p>
          <p class="sobre-about-body">Ao longo dos anos, construímos uma trajetória sólida baseada em projetos bem executados, relacionamentos de confiança e um compromisso inabalável com a excelência. Cada obra entregue carrega nossa assinatura: atenção aos detalhes, cumprimento de prazos e controle financeiro rigoroso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSÃO VISÃO VALORES -->
  <section class="sobre-mvv">
    <div class="sobre-mvv-bg" aria-hidden="true"></div>
    <div class="v2-container">
      <div class="v2-section-header v2-reveal" style="text-align:center;">
        <span class="v2-eyebrow v2-eyebrow-light">PRINCÍPIOS</span>
        <h2 class="v2-section-title v2-light">Missão, Visão &<br /><em>Valores</em></h2>
      </div>
      <div class="sobre-mvv-grid">
        <div class="sobre-mvv-card sobre-mvv-featured v2-reveal">
          <div class="sobre-mvv-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          </div>
          <h3>Missão</h3>
          <p>Materializar projetos de forma transparente, técnica e sofisticada, cuidando de cada etapa do processo construtivo para que nossos clientes tenham tranquilidade absoluta e resultados que superam expectativas.</p>
        </div>
        <div class="sobre-mvv-card v2-reveal v2-reveal-delay-1">
          <div class="sobre-mvv-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Visão</h3>
          <p>Ser a referência em engenharia e construção no litoral catarinense, reconhecida pela qualidade incomparável, inovação constante e pelo compromisso com a satisfação total dos nossos clientes.</p>
        </div>
        <div class="sobre-mvv-card v2-reveal v2-reveal-delay-2">
          <div class="sobre-mvv-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <h3>Valores</h3>
          <p>Transparência em cada relatório financeiro. Qualidade com materiais certificados. Pontualidade rigorosa. Dedicação e atendimento personalizado. Ética e responsabilidade em todas as decisões.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="sobre-diff">
    <div class="v2-container">
      <div class="sobre-diff-header v2-reveal">
        <span class="v2-eyebrow">POR QUE NOS ESCOLHER</span>
        <h2 class="v2-section-title">Nossos<br /><em>Diferenciais</em></h2>
        <div class="v2-title-underline"></div>
      </div>
      <div class="sobre-diff-grid">
        <div class="sobre-diff-item v2-reveal">
          <div class="sobre-diff-num">01</div>
          <div class="sobre-diff-content">
            <h3>Gestão Chave na Mão</h3>
            <p>Cuidamos de absolutamente tudo — desde o primeiro traço do projeto até a entrega das chaves. Você acompanha cada etapa sem nenhuma preocupação.</p>
          </div>
        </div>
        <div class="sobre-diff-item v2-reveal v2-reveal-delay-1">
          <div class="sobre-diff-num">02</div>
          <div class="sobre-diff-content">
            <h3>Transparência Total</h3>
            <p>Relatórios financeiros detalhados, cronogramas atualizados em tempo real e comunicação direta com nossa equipe técnica.</p>
          </div>
        </div>
        <div class="sobre-diff-item v2-reveal v2-reveal-delay-2">
          <div class="sobre-diff-num">03</div>
          <div class="sobre-diff-content">
            <h3>Equipe Qualificada</h3>
            <p>Engenheiros especializados, arquitetos experientes e parceiros selecionados que garantem excelência em cada etapa da obra.</p>
          </div>
        </div>
        <div class="sobre-diff-item v2-reveal">
          <div class="sobre-diff-num">04</div>
          <div class="sobre-diff-content">
            <h3>Prazo Garantido</h3>
            <p>Nosso compromisso com cronogramas é inegociável. Planejamento rigoroso e execução disciplinada para entregar no prazo.</p>
          </div>
        </div>
        <div class="sobre-diff-item v2-reveal v2-reveal-delay-1">
          <div class="sobre-diff-num">05</div>
          <div class="sobre-diff-content">
            <h3>Controle Financeiro</h3>
            <p>Orçamento executivo detalhado desde o primeiro dia. Sem surpresas, sem custos ocultos — apenas clareza e previsibilidade.</p>
          </div>
        </div>
        <div class="sobre-diff-item v2-reveal v2-reveal-delay-2">
          <div class="sobre-diff-num">06</div>
          <div class="sobre-diff-content">
            <h3>Acompanhamento Próximo</h3>
            <p>Atendimento personalizado e acessível. Você tem contato direto com os responsáveis pela sua obra a qualquer momento.</p>
          </div>
        </div>
      </div>
    </div>
  </section>



  <V2CtaSection />
  <V2Footer />
  <FloatingCTA />
</Layout>

<style>
/* ============================
   SOBRE - PAGE HERO
   ============================ */
.sobre-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background: var(--v2-dark);
}
.sobre-hero-bg {
  position: absolute;
  inset: 0;
}
.sobre-hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.85;
  filter: contrast(1.05);
}
.sobre-hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(8,14,23,0.88) 30%, rgba(8,14,23,0.15) 100%),
    linear-gradient(to top, rgba(8,14,23,0.75) 0%, transparent 60%);
}
.sobre-hero-content {
  position: relative;
  z-index: 10;
  padding: 12rem 1.5rem 5rem;
}
.sobre-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--v2-font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--v2-gold);
  border: 1px solid rgba(201,168,76,0.3);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  margin-bottom: 2rem;
  opacity: 0;
  animation: v2fadeUp 0.8s var(--v2-ease-out) 0.1s forwards;
}
.sobre-hero-title {
  display: flex;
  flex-direction: column;
  font-family: var(--v2-font-display);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2px;
  text-transform: uppercase;
  margin: 0 0 1.5rem;
  color: var(--v2-white);
}
.sobre-title-line {
  opacity: 0;
  transform: translateY(30px);
  animation: v2fadeUp 0.8s var(--v2-ease-out) forwards;
}
.sobre-title-accent { color: var(--v2-gold); }
.sobre-title-stroke {
  -webkit-text-stroke: 2px var(--v2-white);
  color: transparent;
}
.sobre-hero-sub {
  font-family: var(--v2-font-serif);
  font-style: italic;
  font-size: clamp(1rem, 1.8vw, 1.25rem);
  color: rgba(240,234,216,0.7);
  line-height: 1.6;
  max-width: 520px;
  margin-bottom: 2rem;
  opacity: 0;
  animation: v2fadeUp 0.8s var(--v2-ease-out) 0.65s forwards;
}
.sobre-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--v2-font-display);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  opacity: 0;
  animation: v2fadeUp 0.8s var(--v2-ease-out) 0.8s forwards;
}
.sobre-breadcrumb a {
  color: var(--v2-muted);
  text-decoration: none;
  transition: color 0.25s;
}
.sobre-breadcrumb a:hover { color: var(--v2-gold); }
.sobre-breadcrumb-sep { color: rgba(255,255,255,0.25); display: flex; }
.sobre-breadcrumb > span:last-child { color: var(--v2-gold); }

@keyframes v2fadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* ============================
   SOBRE - QUEM SOMOS
   ============================ */
.sobre-about {
  padding: 8rem 0;
  background: var(--v2-white);
  position: relative;
}
.sobre-about::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(to right, var(--v2-gold), transparent);
}
.sobre-about-grid {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 6rem;
  align-items: center;
}
.sobre-about-img { position: relative; }
.sobre-about-img .v2-img-frame {
  position: relative;
  aspect-ratio: 4/5;
  border-radius: var(--v2-radius-lg);
  overflow: hidden;
  box-shadow: 0 30px 60px rgba(8,14,23,0.2);
}
.sobre-about-img .v2-img-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--v2-ease);
}
.sobre-about-img .v2-img-frame:hover img { transform: scale(1.04); }
.sobre-about-img .v2-img-frame::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 60%, rgba(8,14,23,0.4));
  z-index: 1;
  pointer-events: none;
}
.sobre-exp-badge {
  position: absolute;
  bottom: -1.5rem;
  right: -1.5rem;
  background: var(--v2-dark);
  color: var(--v2-white);
  padding: 1.5rem 1.75rem;
  border-radius: var(--v2-radius);
  display: flex;
  align-items: center;
  gap: 1rem;
  box-shadow: 0 8px 30px rgba(8,14,23,0.3);
  border: 1px solid var(--v2-border);
  z-index: 2;
}
.sobre-exp-number {
  font-family: var(--v2-font-display);
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--v2-gold);
  line-height: 1;
}
.sobre-exp-label {
  font-family: var(--v2-font-display);
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--v2-muted);
  line-height: 1.4;
}
.sobre-about-text { display: flex; flex-direction: column; }
.sobre-about-text .v2-title-underline {
  width: 50px;
  height: 3px;
  background: var(--v2-gold);
  margin: 1.5rem 0 2rem;
  border-radius: 2px;
}
.sobre-about-lead {
  font-family: var(--v2-font-serif);
  font-style: italic;
  font-size: 1.2rem;
  color: var(--v2-dark-3);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}
.sobre-about-body {
  font-size: 0.95rem;
  color: #555;
  line-height: 1.9;
  margin-bottom: 1.25rem;
}
.sobre-about-body strong { color: var(--v2-dark); font-weight: 700; }

/* ============================
   SOBRE - MISSÃO VISÃO VALORES
   ============================ */
.sobre-mvv {
  position: relative;
  padding: 8rem 0;
  background: var(--v2-dark-2);
  overflow: hidden;
}
.sobre-mvv-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 800px 600px at 20% 50%, rgba(201,168,76,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 600px 400px at 80% 20%, rgba(201,168,76,0.03) 0%, transparent 60%);
  pointer-events: none;
}
.sobre-mvv-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.sobre-mvv-card {
  background: var(--v2-panel);
  border: 1px solid var(--v2-border);
  border-radius: var(--v2-radius-lg);
  padding: 2.5rem;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s var(--v2-ease), border-color 0.3s, box-shadow 0.4s;
  text-align: left;
}
.sobre-mvv-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(to right, var(--v2-gold), transparent);
  opacity: 0;
  transition: opacity 0.4s;
}
.sobre-mvv-card:hover {
  transform: translateY(-6px);
  border-color: rgba(201,168,76,0.2);
  box-shadow: 0 20px 50px rgba(8,14,23,0.4);
}
.sobre-mvv-card:hover::before { opacity: 1; }
.sobre-mvv-featured {
  background: linear-gradient(135deg, rgba(201,168,76,0.12) 0%, var(--v2-panel) 60%);
  border-color: rgba(201,168,76,0.2);
}
.sobre-mvv-featured::before { opacity: 1; }
.sobre-mvv-icon {
  width: 56px;
  height: 56px;
  background: var(--v2-gold-muted);
  border-radius: var(--v2-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
  border: 1px solid rgba(201,168,76,0.2);
  transition: background 0.3s, transform 0.3s;
}
.sobre-mvv-card:hover .sobre-mvv-icon {
  background: rgba(201,168,76,0.2);
  transform: scale(1.05);
}
.sobre-mvv-icon svg { stroke: var(--v2-gold); }
.sobre-mvv-card h3 {
  font-family: var(--v2-font-display);
  font-size: 1.1rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--v2-white);
  margin-bottom: 1rem;
  line-height: 1.2;
}
.sobre-mvv-card p {
  font-size: 0.9rem;
  color: var(--v2-muted);
  line-height: 1.8;
}

/* ============================
   SOBRE - DIFERENCIAIS
   ============================ */
.sobre-diff {
  padding: 8rem 0;
  background: var(--v2-white);
  position: relative;
}
.sobre-diff::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(to right, var(--v2-gold), transparent);
}
.sobre-diff-header {
  margin-bottom: 4rem;
}
.sobre-diff-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.sobre-diff-item {
  display: flex;
  gap: 1.25rem;
  padding: 2rem;
  background: rgba(8,14,23,0.02);
  border-radius: var(--v2-radius-lg);
  border: 1px solid rgba(8,14,23,0.06);
  transition: transform 0.4s var(--v2-ease), box-shadow 0.4s, border-color 0.3s;
}
.sobre-diff-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(8,14,23,0.08);
  border-color: rgba(201,168,76,0.25);
}
.sobre-diff-num {
  font-family: var(--v2-font-display);
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--v2-gold);
  line-height: 1;
  flex-shrink: 0;
  opacity: 0.5;
}
.sobre-diff-content h3 {
  font-family: var(--v2-font-display);
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--v2-dark);
  margin-bottom: 0.5rem;
}
.sobre-diff-content p {
  font-size: 0.88rem;
  color: #666;
  line-height: 1.7;
}



/* ============================
   RESPONSIVE
   ============================ */
@media (max-width: 900px) {
  .sobre-about-grid { grid-template-columns: 1fr; gap: 3rem; }
  .sobre-about-img { order: -1; }
  .sobre-about-img .v2-img-frame { aspect-ratio: 16/9; max-height: 400px; }
  .sobre-exp-badge { bottom: -1rem; right: 0.5rem; }
  .sobre-mvv-grid { grid-template-columns: 1fr; gap: 1rem; }
  .sobre-diff-grid { grid-template-columns: 1fr; gap: 1.25rem; }
}

@media (max-width: 600px) {
  .sobre-hero-content { padding: 9rem 1rem 4rem; }
  .sobre-diff-item { flex-direction: column; gap: 0.75rem; }
}
</style>

<script>
  // Scroll reveal
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.v2-reveal').forEach(el => revealObserver.observe(el));
</script>
